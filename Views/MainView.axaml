<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:chession.ViewModels"
             xmlns:conv="using:chession.Converters"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="400" d:DesignHeight="400"
             x:Class="chession.Views.MainView"
             x:DataType="vm:MainViewModel">

    <Grid Background="#262626">
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="24">

            <TextBlock Text="{Binding Profile.Username}"
                       FontSize="24"
                       FontWeight="Bold"
                       Foreground="White"
                       HorizontalAlignment="Center" />

            <ProgressBar IsIndeterminate="True"
                         IsVisible="{Binding IsLoading}"
                         Height="4" />

            <TextBlock Text="{Binding ErrorMessage}"
                       Foreground="Red"
                       HorizontalAlignment="Center"
                       TextWrapping="Wrap"
                       TextAlignment="Center"
                       IsVisible="{Binding ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />

            <Border Background="#1A1A1A" CornerRadius="8" Padding="24,16"
                    HorizontalAlignment="Center">
                <TextBlock Text="{Binding SessionScore}"
                           FontSize="48"
                           FontWeight="Bold"
                           Foreground="White"
                           HorizontalAlignment="Center" />
            </Border>

            <ItemsControl ItemsSource="{Binding DisplaySlots}"
                          HorizontalAlignment="Center">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="vm:GameSlot">
                        <Border Width="32" Height="32" Margin="2" CornerRadius="4"
                                Background="{Binding Result, Converter={x:Static conv:ResultToColorConverter.Instance}}" />
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <StackPanel IsVisible="{Binding HasOverflow}" Spacing="8">
                <ToggleButton IsChecked="{Binding IsOverflowExpanded}"
                              HorizontalAlignment="Center"
                              Background="Transparent"
                              BorderBrush="#555"
                              Foreground="#AAA"
                              Padding="12,6"
                              Content="Show all games ▼" />

                <Border IsVisible="{Binding IsOverflowExpanded}"
                        Background="#1A1A1A" CornerRadius="8" Padding="8"
                        HorizontalAlignment="Center"
                        MaxWidth="380">
                    <ItemsControl ItemsSource="{Binding CompletedGames}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel Orientation="Horizontal" MaxWidth="360" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Width="32" Height="32" Margin="2" CornerRadius="4"
                                        Background="{Binding Converter={x:Static conv:ResultToColorConverter.Instance}}" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Border>
            </StackPanel>

        </StackPanel>
    </Grid>
</UserControl>
